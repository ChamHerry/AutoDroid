          <mxGeometry x="780" y="575" width="320" height="300" as="geometry" />
        </mxCell>
        <mxCell id="inrt-panel-title" value="&lt;b&gt;INRT Packaged Script Flow&lt;/b&gt;" style="text;html=1;fontSize=13;fontStyle=1;fontColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="790" y="580" width="280" height="25" as="geometry" />
        </mxCell>
        <mxCell id="inrt-step1" value="1. AssetsProjectLauncher.prepare()&#xa;   Load project.json&#xa;   Check buildId (incremental)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="615" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="inrt-step2" value="2. Copy assets/project/ → filesDir&#xa;   Init encryption key:&#xa;   key=MD5(pkg+ver+main)&#xa;   iv=MD5(buildId+name)[0:16]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="680" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="inrt-step3" value="3. XJavaScriptEngine.execute()&#xa;   Check EncryptedScriptFileHeader&#xa;   → ScriptEncryption.decrypt()&#xa;   → Execute as StringScriptSource" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="755" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="inrt-step4" value="4. ROOT auto-enable&#xa;   AccessibilityService&#xa;   (timeout 2s)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="800" y="830" width="280" height="35" as="geometry" />
        </mxCell>

