        <!-- Observer Notification -->
        <mxCell id="observer" value="&lt;b&gt;ScriptExecutionObserver&lt;/b&gt;&#xa;&#xa;├─ onSuccess(execution, result)  → globalConsole.log()&#xa;├─ onException(execution, e)     → globalConsole.error()&#xa;└─ ScriptExecutionGlobalListener  → EventBus notify" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="1610" width="420" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a18" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="exec-result" target="observer">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Engine Destroy -->
        <mxCell id="destroy" value="&lt;b&gt;engine.destroy()&lt;/b&gt;&#xa;&#xa;├─ runtime.onExit() → cleanup all resources&#xa;├─ sContextEngineMap.remove(context)&#xa;└─ Context.exit() → release Rhino context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="200" y="1730" width="420" height="70" as="geometry" />
