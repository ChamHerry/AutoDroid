        <!-- Arrow -> ScriptEngineService -->
        <mxCell id="a7" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="autojs-inst" target="ses">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ScriptEngineService -->
        <mxCell id="ses" value="&lt;b&gt;ScriptEngineService.execute(ScriptSource, ExecutionConfig)&lt;/b&gt;&#xa;&#xa;1. Create ScriptExecutionTask(source, listener, config)&#xa;2. Wrap as RunnableScriptExecution / LoopedBasedJavaScriptExecution&#xa;3. Submit to executor (new Thread)&#xa;4. Notify ScriptExecutionObserver.onStart()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="430" width="520" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow -> ScriptEngineManager -->
        <mxCell id="a8" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ses" target="sem">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ScriptEngineManager -->
        <mxCell id="sem" value="&lt;b&gt;ScriptEngineManager.createEngineOfSource(source)&lt;/b&gt;&#xa;&#xa;Lookup: source.getEngineName() → Engine Supplier Map&#xa;JavaScriptSource → RhinoJavaScriptEngine&#xa;AutoFileSource → RhinoJavaScriptEngine&#xa;RootAutomator → RootAutomatorEngine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="575" width="520" height="90" as="geometry" />
        </mxCell>

        <!-- Arrow -> Engine Init -->
        <mxCell id="a9" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="sem" target="engine-init">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Engine Initialization -->
        <mxCell id="engine-init" value="&lt;b&gt;RhinoJavaScriptEngine.init()&lt;/b&gt;&#xa;&#xa;1. enterContext() → AndroidContextFactory.enterContext()&#xa;2. createScope() → new TopLevelScope (ImporterTopLevel)&#xa;3. initRequireBuilder() → CommonJS module system&#xa;4. Execute init.js (bootstrap script from assets)&#xa;5. Set optimization level = -1 (interpreted mode)&#xa;6. Set language version = ES6" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="710" width="520" height="110" as="geometry" />
        </mxCell>

        <!-- Arrow -> Runtime Init -->
        <mxCell id="a10" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="engine-init" target="runtime-init">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Runtime Initialization -->
        <mxCell id="runtime-init" value="&lt;b&gt;JavaScriptEngine.setRuntime(ScriptRuntime)&lt;/b&gt;&#xa;&#xa;ScriptRuntime.init() → Initialize all API modules:&#xa;├─ threads = new Threads(runtime)&#xa;├─ timers = new Timers(runtime)&#xa;├─ loopers = new Loopers(runtime)&#xa;├─ events = new Events(context, accessibilityBridge, runtime)&#xa;└─ sensors = new Sensors(context, runtime)&#xa;&#xa;Inject into scope: engine.put(&quot;runtime&quot;, runtime)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="860" width="520" height="130" as="geometry" />
        </mxCell>

        <!-- Arrow -> Source Check -->
        <mxCell id="a11" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="runtime-init" target="source-check">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Source Mode Check -->
        <mxCell id="source-check" value="&lt;b&gt;JavaScriptSource.getExecutionMode()&lt;/b&gt;&#xa;&#xa;Scan first 300 tokens using Rhino TokenStream:&#xa;├─ &quot;ui&quot;;  → EXECUTION_MODE_UI (0x01) → setup UI thread&#xa;├─ &quot;auto&quot;; → EXECUTION_MODE_AUTO (0x02)&#xa;│           → ensureAccessibilityServiceEnabled()&#xa;└─ (none) → EXECUTION_MODE_NORMAL (0x00)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="1030" width="520" height="100" as="geometry" />
        </mxCell>

        <!-- Arrow -> Compile -->
        <mxCell id="a12" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="source-check" target="compile">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Compilation -->
        <mxCell id="compile" value="&lt;b&gt;RhinoJavaScriptEngine.doExecution(source)&lt;/b&gt;&#xa;&#xa;1. reader = source.getNonNullScriptReader()&#xa;2. reader = preprocess(reader) → script preprocessing&#xa;3. script = context.compileReader(reader, sourceName, lineNo, null)&#xa;   → Rhino AST → Interpreted bytecode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="1175" width="520" height="90" as="geometry" />
        </mxCell>

        <!-- Decision: Continuation? -->
        <mxCell id="decision" value="hasFeature&#xa;(CONTINUATION)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="340" y="1310" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="a13" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="compile" target="decision">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Yes: Continuation -->
        <mxCell id="exec-cont" value="&lt;b&gt;context.executeScript&#xa;WithContinuations()&lt;/b&gt;&#xa;(supports pause/resume)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="180" y="1420" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a14" style="rounded=1;strokeWidth=2;exitX=0;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="decision" target="exec-cont">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a14l" value="Yes" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="a14">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- No: Normal -->
        <mxCell id="exec-normal" value="&lt;b&gt;script.exec&#xa;(context, scope)&lt;/b&gt;&#xa;(standard execution)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="460" y="1420" width="170" height="70" as="geometry" />
        </mxCell>
        <mxCell id="a15" style="rounded=1;strokeWidth=2;exitX=1;exitY=0.5;entryX=0.5;entryY=0;" edge="1" parent="1" source="decision" target="exec-normal">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a15l" value="No" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="a15">
