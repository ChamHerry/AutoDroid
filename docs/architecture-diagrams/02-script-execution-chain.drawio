        </mxCell>

        <!-- Both converge to Execution Result -->
        <mxCell id="exec-result" value="&lt;b&gt;Execution Result&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="1530" width="200" height="40" as="geometry" />
