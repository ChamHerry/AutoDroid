        <!-- ===== MIDDLE: Search Algorithm ===== -->
        <mxCell id="search-alg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="900" width="560" height="200" as="geometry" />
        </mxCell>
        <mxCell id="sa-title" value="&lt;b&gt;Search Algorithms&lt;/b&gt;" style="text;html=1;fontSize=14;fontStyle=1;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="70" y="905" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="dfs-box" value="&lt;b&gt;DFS (Depth-First Search)&lt;/b&gt;&#xa;&#xa;Uses Stack (LinkedList)&#xa;Push children in reverse order&#xa;&#xa;while stack not empty:&#xa;  node = stack.pop()&#xa;  push children[n-1..0]&#xa;  if filter.filter(node):&#xa;    result.add(node)&#xa;    if result.size &gt;= limit: break&#xa;  else: node.recycle()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="935" width="250" height="155" as="geometry" />
        </mxCell>

        <mxCell id="bfs-box" value="&lt;b&gt;BFS (Breadth-First Search)&lt;/b&gt;&#xa;&#xa;Uses Queue (ArrayDeque)&#xa;Enqueue children in order&#xa;&#xa;while queue not empty:&#xa;  node = queue.poll()&#xa;  enqueue children[0..n-1]&#xa;  if filter.filter(node):&#xa;    result.add(node)&#xa;    if result.size &gt;= limit: break&#xa;  else: node.recycle()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="935" width="250" height="155" as="geometry" />
        </mxCell>

        <!-- ===== BOTTOM: UiObject & AccessibilityService ===== -->
        <mxCell id="bottom-title" value="System Level Execution" style="text;html=1;fontSize=16;fontStyle=5;fontColor=#432D57;" vertex="1" parent="1">
          <mxGeometry x="60" y="1140" width="300" height="30" as="geometry" />
        </mxCell>

        <!-- UiObject -->
        <mxCell id="uiobject" value="&lt;b&gt;UiObject&lt;/b&gt; extends AccessibilityNodeInfoCompat&#xa;&#xa;Actions:                          Properties:&#xa;click() → ACTION_CLICK           text() → getText()&#xa;longClick() → ACTION_LONG_CLICK   desc() → getContentDescription()&#xa;setText(s) → ACTION_SET_TEXT      id() → getViewIdResourceName()&#xa;scrollUp/Down/Left/Right()        bounds() → getBoundsInScreen()&#xa;focus() → ACTION_FOCUS            className() → getClassName()&#xa;paste() → ACTION_PASTE            depth() → computed&#xa;&#xa;Tree Navigation: parent() | child(i) | children() | childCount()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1180" width="500" height="180" as="geometry" />
        </mxCell>

        <!-- AccessibilityService -->
        <mxCell id="a11y-service" value="&lt;b&gt;AccessibilityService&lt;/b&gt; (automator module)&#xa;&#xa;Event Processing:&#xa;onAccessibilityEvent(event) → dispatch to delegates&#xa;├─ TYPE_WINDOW_STATE_CHANGED → update mFastRootInActiveWindow&#xa;├─ TYPE_VIEW_FOCUSED → update cached root&#xa;└─ delegate.onAccessibilityEvent() → break on handled&#xa;&#xa;Node Access:&#xa;rootInActiveWindow → full UI tree root&#xa;fastRootInActiveWindow() → cached root (faster)&#xa;&#xa;Global Actions:&#xa;back() | home() | recents() | notifications()&#xa;&#xa;Gestures (API 24+):&#xa;gesture(start, duration, points[])&#xa;swipe(x1,y1,x2,y2,delay)&#xa;click(x,y) | longClick(x,y) | press(x,y,delay)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#76608a;fontColor=#ffffff;strokeColor=#432D57;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="1410" width="500" height="260" as="geometry" />
        </mxCell>
        <mxCell id="arr8" style="rounded=1;strokeWidth=2;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="uiobject" target="a11y-service">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="arr8l" value="performAction()" style="edgeLabel;html=1;fontSize=10;" vertex="1" connectable="0" parent="arr8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Android System -->
        <mxCell id="android-sys" value="&lt;b&gt;Android System&lt;/b&gt;&#xa;AccessibilityNodeInfo.performAction()&#xa;AccessibilityService.performGlobalAction()&#xa;AccessibilityService.dispatchGesture()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#333333;fontColor=#ffffff;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="130" y="1720" width="350" height="70" as="geometry" />
