        <mxCell id="arr9" style="rounded=1;strokeWidth=2;strokeColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="a11y-service" target="android-sys">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ===== RIGHT: GlobalActionAutomator ===== -->
        <mxCell id="global-action" value="&lt;b&gt;GlobalActionAutomator&lt;/b&gt;&#xa;(Coordinate-based actions)&#xa;&#xa;Navigation:&#xa;├─ back() → GLOBAL_ACTION_BACK&#xa;├─ home() → GLOBAL_ACTION_HOME&#xa;├─ recents() → GLOBAL_ACTION_RECENTS&#xa;├─ notifications() → GLOBAL_ACTION_NOTIFICATIONS&#xa;├─ quickSettings()&#xa;├─ splitScreen() (API 24+)&#xa;└─ powerDialog() (API 21+)&#xa;&#xa;Gestures:&#xa;├─ click(x, y) → 1px gesture&#xa;├─ longClick(x, y) → 400ms press&#xa;├─ swipe(x1,y1,x2,y2,delay)&#xa;├─ gesture(start, duration, points[])&#xa;└─ gesturesAsync(StrokeDescription...)&#xa;&#xa;ScreenMetrics:&#xa;Coordinate scaling for different resolutions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="1180" width="300" height="310" as="geometry" />
