        </mxCell>
        <mxCell id="subtitle" value="Channel A: Node.js (JNI+N-API, planned)  |  Channel B: HTTP REST API (implemented)" style="text;html=1;fontSize=12;fontStyle=2;align=center;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="250" y="50" width="700" height="20" as="geometry" />
