          <mxGeometry x="55" y="90" width="300" height="20" as="geometry" />
        </mxCell>

        <mxCell id="user-script" value='&lt;b&gt;User Script (ES2024)&lt;/b&gt;&#xa;&#xa;import { click } from &quot;@autojs/automator&quot;;&#xa;import { launchApp } from &quot;@autojs/app&quot;;&#xa;&#xa;await launchApp(&quot;com.tencent.mm&quot;);&#xa;const btn = await selector({text:&quot;OK&quot;}).findOne();&#xa;await btn.click();' style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;spacingLeft=12;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="60" y="115" width="330" height="130" as="geometry" />
        </mxCell>

        <mxCell id="nodejs-rt" value="&lt;b&gt;Node.js 22 LTS&lt;/b&gt;&#xa;V8 + libuv&#xa;Worker Threads&#xa;@autojs/* SDK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd966;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="115" width="130" height="70" as="geometry" />
        </mxCell>

